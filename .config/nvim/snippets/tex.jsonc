    "My Template": {
        "prefix": ["mytemplate", "\\mytemplate"],
        "body": [
            "%! TEX program = xelatex",
            "\\documentclass{article}",
            "\\usepackage[scheme=plain]{ctex}",
            "\\usepackage{amsmath}",
            "\\usepackage{amssymb}",
            "\\usepackage{amsthm}",
